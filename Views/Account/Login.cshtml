
@{
    ViewBag.Title = "تسجيل الدخول";
}


<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تسجيل الدخول</title>

    <!-- Font Awesome للأيقونات -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        body {
            background: linear-gradient(135deg, #eef2ff, #dbeafe);
            
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
        }

        /* توسيط الصفحة */
        .login-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        /* حركة */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* الكارد */
        .login-container {
            width: 90%;
            max-width: 420px;
            padding: 30px;
            background: #ffffff;
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(106, 27, 154, 0.2);
            text-align: center;
            animation: fadeInUp 0.6s ease;
            transition: 0.3s;
        }

            .login-container:hover {
                transform: translateY(-5px);
            }

        /* اللوجو */
        .logo {
            font-size: 50px;
            margin-bottom: 10px;
            color: #6a1b9a;
        }

        .app-name {
            font-size: 24px;
            margin-bottom: 20px;
            color: #6a1b9a;
            font-weight: bold;
        }

        /* الحقول */
        .form-control {
            width: 80%;
            margin: 0 auto 15px auto;
            display: block;
            border-radius: 12px;
            padding: 12px;
            font-size: 14px;
            border: 1px solid #ddd;
            transition: 0.3s;
        }

            .form-control:focus {
                border-color: #9c27b0;
                outline: none;
                box-shadow: 0 0 8px rgba(156,39,176,0.3);
            }

            .form-control:hover {
                border-color: #9c27b0;
            }

        /* الزر */
        .btn-login {
            background: #1E3A8A;
            border: none;
            color: #fff;
            width: 80%;
            padding: 12px;
            border-radius: 25px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
            font-weight: bold;
            letter-spacing: 1px;
            display: block;
            margin: 10px auto 0 auto;
        }

            .btn-login:hover {
                transform: scale(1.03);
                box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            }

            .btn-login:active {
                transform: scale(0.97);
            }

        /* روابط */
        .register {
            margin-top: 15px;
        }

            .register a {
                color: #0d1b2a;
                font-weight: bold;
                text-decoration: none;
            }

        /* أيقونات */
        .icons {
            margin-top: 20px;
            color: #888;
        }

            .icons i {
                margin: 0 10px;
                cursor: pointer;
                transition: 0.3s;
            }

                .icons i:hover {
                    color: #9c27b0;
                    transform: scale(1.2);
                }

        /* الجوال */
        @@media (max-width: 480px) {
            .login-container {
                padding: 20px;
                border-radius: 15px;
            }

            .logo {
                font-size: 40px;
            }

            .app-name {
                font-size: 20px;
            }
        }
    </style>
</head>

<body>

    <div class="login-wrapper">
        <div class="login-container">

            <div class="logo">
                <img src="@Url.Content("~/Images/لقطة شاشة 2026-04-26 230930.png")" alt="شعار معين" style="width: 50px; height: auto;" />
            </div>
           
            <h4>تسجيل الدخول</h4>

            @if (ViewBag.Error != null)
            {
                <p style="color:red">@ViewBag.Error</p>}

            <form method="post">
                <input type="email" name="Email" class="form-control" placeholder="البريد الإلكتروني" required />
                <input type="password" name="Password" class="form-control" placeholder="كلمة المرور" required />

                <button type="submit" class="btn-login">دخول</button>
            </form>

            <div class="register">
                <p>ما عندك حساب؟</p>
                <a href="/Account/Register">إنشاء حساب جديد</a>
            </div>

            <div class="icons">
                <i class="fa fa-instagram"></i>
                <i class="fa fa-twitter"></i>
                <i class="fa fa-envelope"></i>
            </div>

        </div>
    </div>

</body>
</html>
<a href="/Account/Register">إنشاء حساب جديد</a>



