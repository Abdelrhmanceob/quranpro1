@model IEnumerable<Maeen1_New.Models.RecitationRequest>
@{
    ViewBag.Title = "طلبات التسميع";
    var teacherId = (int)ViewBag.TeacherId;
    var linkedStudents = ViewBag.LinkedStudents as IEnumerable<Maeen1_New.Models.ViewModels.TeacherLinkedStudentSessionViewModel>;
    var studentVoiceUrls = ViewBag.StudentVoiceUrls as IDictionary<int, string>;
    var teacherVoiceUrls = ViewBag.TeacherVoiceUrls as IDictionary<int, string>;
    var studentScreenUrls = ViewBag.StudentScreenUrls as IDictionary<int, string>;
    var teacherScreenUrls = ViewBag.TeacherScreenUrls as IDictionary<int, string>;
}

<h2>طلبات التسميع</h2>

<div style="margin-bottom: 15px;">
    <a href="@Url.Action("Dashboard", "Teacher", new { userId = teacherId })" class="btn btn-default">لوحة المدرس</a>
    <a href="@Url.Action("ExamManagement", "Teacher", new { userId = teacherId })" class="btn btn-info">حفظي (المهام والاختبارات)</a>
</div>

@if (linkedStudents != null && linkedStudents.Any())
{
    <div class="panel panel-default" style="margin-bottom:20px;">
        <div class="panel-heading">
            <strong>الطلاب المرتبطون مع المعلم</strong>
        </div>
        <div class="panel-body">
            <table class="table table-bordered table-condensed">
                <thead>
                    <tr>
                        <th>اسم الطالب</th>
                        <th>طلبات التسميع</th>
                        <th>جلسات جاهزة</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in linkedStudents)
                    {
                        <tr>
                            <td>@student.StudentName</td>
                            <td>@student.TotalRecitationRequests</td>
                            <td>@student.ReadySessions</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">لا توجد طلبات تسميع حالياً.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>رقم الطلب</th>
                <th>الطالب</th>
                <th>ملاحظات الطالب</th>
                <th>الحالة</th>
                <th>رابط Google Meet</th>
                <th>صوت الطالب</th>
                <th>رد المعلم الصوتي</th>
                <th>ريكورد شاشة الطالب</th>
                <th>التقييم</th>
                <th>ريكورد شاشة المعلم</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.Id</td>
                    <td>@(request.Student != null ? request.Student.Name : "غير معروف")</td>
                    <td>@(string.IsNullOrWhiteSpace(request.Notes) ? "-" : request.Notes)</td>
                    <td>
                        @if (request.Session != null && !string.IsNullOrWhiteSpace(request.Session.GoogleMeetUrl))
                        {
                            <span class="label label-success">تمت الجدولة</span>
                        }
                        else
                        {
                            <span class="label label-warning">معلق</span>
                        }
                    </td>
                    <td>
                        @using (Html.BeginForm("SaveMeetLink", "Teacher", FormMethod.Post, new { @class = "form-inline" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="teacherId" value="@teacherId" />
                            <input
                                type="url"
                                name="meetUrl"
                                class="form-control input-sm"
                                style="min-width:280px"
                                placeholder="https://meet.google.com/..."
                                value="@(request.Session != null ? request.Session.GoogleMeetUrl : string.Empty)"
                                required />
                            <button type="submit" class="btn btn-primary btn-sm">حفظ الرابط</button>
                        }
                    </td>
                    <td style="min-width: 260px;">
                        @if (studentVoiceUrls != null && studentVoiceUrls.ContainsKey(request.Id))
                        {
                            <audio controls preload="none" src="@studentVoiceUrls[request.Id]" style="width:100%"></audio>
                        }
                        else
                        {
                            <span class="text-muted">لا يوجد تسجيل من الطالب</span>
                        }
                    </td>
                    <td style="min-width: 280px;">
                        @using (Html.BeginForm("UploadTeacherRecitationVoice", "Teacher", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-inline", style = "display:flex;gap:6px;align-items:center;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="teacherId" value="@teacherId" />
                            <input type="file" name="voiceFile" accept="audio/*" class="form-control input-sm" required />
                            <button type="submit" class="btn btn-success btn-sm">رفع الرد</button>
                        }
                        @if (teacherVoiceUrls != null && teacherVoiceUrls.ContainsKey(request.Id))
                        {
                            <div style="margin-top:8px;">
                                <audio controls preload="none" src="@teacherVoiceUrls[request.Id]" style="width:100%"></audio>
                            </div>
                        }
                    </td>
                    <td style="min-width: 300px;">
                        @if (studentScreenUrls != null && studentScreenUrls.ContainsKey(request.Id))
                        {
                            <video controls preload="metadata" src="@studentScreenUrls[request.Id]" style="width:100%;max-height:220px;"></video>
                        }
                        else
                        {
                            <span class="text-muted">لا يوجد ريكورد شاشة من الطالب</span>
                        }
                    </td>
                    <td style="min-width: 320px;">
                        @{
                            var hasStudentVoice = studentVoiceUrls != null && studentVoiceUrls.ContainsKey(request.Id);
                            var hasStudentScreen = studentScreenUrls != null && studentScreenUrls.ContainsKey(request.Id);
                            var showTeacherEvaluation = hasStudentVoice || hasStudentScreen;
                        }
                        @if (showTeacherEvaluation)
                        {
                            @using (Html.BeginForm("SubmitTeacherRecitationEvaluation", "Teacher", FormMethod.Post, new { style = "max-width:360px;" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <input type="hidden" name="teacherId" value="@teacherId" />
                                <div class="form-group" style="margin-bottom:6px;">
                                    <label class="small">الدرجة المحصلة</label>
                                    <input type="number" step="0.01" name="score" class="form-control input-sm" />
                                </div>
                                <div class="form-group" style="margin-bottom:6px;">
                                    <label class="small">الدرجة الكاملة</label>
                                    <input type="number" step="0.01" name="maxScore" class="form-control input-sm" />
                                </div>
                                <div class="form-group" style="margin-bottom:6px;">
                                    <label class="small">التقدير</label>
                                    <input type="text" name="grade" class="form-control input-sm" placeholder="مثال: ممتاز" />
                                </div>
                                <div class="form-group" style="margin-bottom:6px;">
                                    <label class="small">ملاحظات</label>
                                    <textarea name="teacherNotes" class="form-control input-sm" rows="2"></textarea>
                                </div>
                                <div class="form-group" style="margin-bottom:6px;">
                                    <label class="small">نقاط القوة</label>
                                    <textarea name="strengths" class="form-control input-sm" rows="2"></textarea>
                                </div>
                                <div class="form-group" style="margin-bottom:6px;">
                                    <label class="small">نقاط الضعف</label>
                                    <textarea name="weaknesses" class="form-control input-sm" rows="2"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm btn-block">حفظ التقييم</button>
                            }
                        }
                        else
                        {
                            <span class="text-muted small">يظهر بعد إرسال الطالب للصوت أو ريكورد الشاشة</span>
                        }
                    </td>
                    <td style="min-width: 320px;">
                        @using (Html.BeginForm("UploadTeacherRecitationScreen", "Teacher", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-inline", style = "display:flex;gap:6px;align-items:center;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="teacherId" value="@teacherId" />
                            <input type="file" name="screenFile" accept="video/*" class="form-control input-sm" required />
                            <button type="submit" class="btn btn-success btn-sm">رفع الرد</button>
                        }
                        @if (teacherScreenUrls != null && teacherScreenUrls.ContainsKey(request.Id))
                        {
                            <div style="margin-top:8px;">
                                <video controls preload="metadata" src="@teacherScreenUrls[request.Id]" style="width:100%;max-height:220px;"></video>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a href="@Url.Action("Dashboard", "Teacher", new { userId = teacherId })" class="btn btn-default">العودة للوحة المدرس</a>