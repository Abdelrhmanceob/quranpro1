@model Maeen1_New.Models.ViewModels.StudentOnboardingWizardViewModel
@{
    Layout = null;
    ViewBag.Title = "اختبار تحديد المستوى";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            font-family: "Tajawal", sans-serif;
            background: linear-gradient(135deg, #f9f9ff, #e7eefe);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            color: #151c27;
        }

        .card {
            width: 100%;
            max-width: 760px;
            background: #fff;
            border: 1px solid #dce2f3;
            border-radius: 16px;
            box-shadow: 0 18px 36px rgba(6,95,70,0.08);
            padding: 24px;
        }

        h2 {
            margin-top: 0;
            color: #065f46;
        }

        .note {
            margin-top: 0;
            color: #4b5b66;
        }

        .field {
            margin-bottom: 14px;
        }

        label {
            font-weight: 700;
            display: block;
            margin-bottom: 6px;
        }

        input, select {
            width: 100%;
            border: 1px solid #c8d2ec;
            border-radius: 10px;
            padding: 11px;
            font-family: inherit;
            font-size: 15px;
        }

        input:focus, select:focus {
            outline: 0;
            border-color: #065f46;
            box-shadow: 0 0 0 3px rgba(6,95,70,0.12);
        }

        .error {
            color: #ba1a1a;
            margin-top: 4px;
            font-size: 14px;
        }

        .btn {
            border: 0;
            border-radius: 10px;
            background: #065f46;
            color: #fff;
            font-family: inherit;
            font-size: 16px;
            font-weight: 700;
            padding: 12px 18px;
            cursor: pointer;
            width: 100%;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>اختبار تحديد المستوى</h2>
        <p class="note">أجب على الأسئلة التالية ليتم إنشاء خطة حفظ مناسبة وعرض نتيجة التقييم داخل لوحة الطالب.</p>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        @using (Html.BeginForm("OnboardingWizard", "Student", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.UserId)

            <div class="field">
                <label>1) عدد ساعات الحفظ اليومية</label>
                @Html.TextBoxFor(m => m.DailyMemorizationHours, new { type = "number", min = "1", max = "12" })
                @Html.ValidationMessageFor(m => m.DailyMemorizationHours, "", new { @class = "error" })
            </div>

            <div class="field">
                <label>2) عدد الأجزاء المستهدفة</label>
                @Html.TextBoxFor(m => m.TargetJuzCount, new { type = "number", min = "1", max = "30" })
                @Html.ValidationMessageFor(m => m.TargetJuzCount, "", new { @class = "error" })
            </div>

            <div class="field">
                <label>3) الأجزاء المحفوظة مسبقًا</label>
                @Html.TextBoxFor(m => m.CompletedJuzCount, new { type = "number", min = "0", max = "30" })
                @Html.ValidationMessageFor(m => m.CompletedJuzCount, "", new { @class = "error" })
            </div>

            <div class="field">
                <label>4) مستوى التجويد</label>
                @Html.DropDownListFor(
                    m => m.TajweedLevel,
                    new SelectList(new[]
                    {
                        new { Value = "", Text = "-- اختر --" },
                        new { Value = "مبتدئ", Text = "مبتدئ" },
                        new { Value = "متوسط", Text = "متوسط" },
                        new { Value = "متقدم", Text = "متقدم" }
                    }, "Value", "Text"))
                @Html.ValidationMessageFor(m => m.TajweedLevel, "", new { @class = "error" })
            </div>

            <div class="field">
                <label>5) المدة الزمنية المستهدفة</label>
                @Html.TextBoxFor(m => m.TargetDuration, new { placeholder = "مثال: 6 أشهر" })
                @Html.ValidationMessageFor(m => m.TargetDuration, "", new { @class = "error" })
            </div>

            <button type="submit" class="btn">حفظ وإكمال التقييم</button>
        }
    </div>
</body>
</html>
