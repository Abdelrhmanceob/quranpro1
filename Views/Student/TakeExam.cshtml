@{
    ViewBag.Title = "الاختبار - " + ViewBag.ExamTitle;
}

<div class="text-center" style="margin-top: 40px;">
    <div class="panel panel-success">
        <div class="panel-heading">
            <h2>@ViewBag.ExamTitle</h2>
        </div>
        <div class="panel-body">
            @if (!string.IsNullOrEmpty((string)ViewBag.ExamDescription))
            {
                <p class="lead">@ViewBag.ExamDescription</p>
                <hr />
            }
            <div class="alert alert-success">
                <h3>تم فتح الاختبار بنجاح!</h3>
                <p>يمكنك الآن البدء في الاختبار. بالتوفيق!</p>
            </div>

            <div class="well" style="margin-top: 30px; padding: 30px;">
                <h4>محتوى الاختبار</h4>
                <p class="text-muted">سيتم عرض أسئلة الاختبار هنا...</p>
                <!-- Placeholder for exam content - to be expanded later -->
            </div>
        </div>
    </div>
</div>

<div style="margin-top: 20px;">
    <a href="@Url.Action("MyExams", "Student", new { userId = ViewBag.StudentId })" class="btn btn-default">
        العودة لقائمة الاختبارات
    </a>
</div>
