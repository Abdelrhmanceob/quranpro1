                        "https://lh3.googleusercontent.com/aida-public/AB6AXuDTRdDriub9GivKSChu4B1a8LYK6q6RKZT2-swXMe5mbJJevO8sFiuSYRrtnJBQAME5luMU1MxYeIm7H2-26e2Hv3SnPJuuTfgj6Hhu30GJjGM3el7qt8DZbrqa1NHLfHPeqUba2Jn7FR3_1xZ_DdvqQ93d5RBGw-ueOg938yArLEAAxRFmR_XS0c94fh9RfPgAgrz16XUcS5wvzimYl0vPCDHCgo13xGMTLzvdGtK0c-NtYldQvqejUSXpTS0PQJkD4I0HMBfiD3pP",
                        "https://lh3.googleusercontent.com/aida-public/AB6AXuBhsg0jhCLjkKC0B2K8EMmv2LxaZ_HRpBgZbhsLjZdI700_SJM8brAdA-HZxwxjuhnM1R2iwFt2Sfa5STaT1Pd42HqncEQmh-KpglcD_SOCrRC1pVfElsfLS1u-Pg5ivAAin7h6HHFWs_jhoaUAvM7JPd_dp2FC9hxObR9mfBxzMb3eowiL6E2VvKS-xYopXJO1swE3FQABevEPjr15WsoOuLLVClv3R-m5rVmlymk3pf8Sie3S3Kh9KptU4yQ2iWBedkeKBFPpUVn1"
                    };
                    var index = 0;
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        @foreach (var teacher in teachers)
                        {
                            var avatar = teacherImages[index % teacherImages.Length];
                            index++;
                            <div class="rounded-2xl border border-outline-variant bg-surface-container-low p-4">
                                <div class="flex items-start gap-3">
                                    <img src="@avatar" alt="صورة المدرس" class="w-16 h-16 rounded-xl object-cover border border-outline-variant" />
                                    <div>
                                        <div class="font-bold text-sm">@teacherValueOf(teacher, "Name")</div>
                                        <div class="text-xs text-on-surface-variant">@(string.IsNullOrWhiteSpace(teacherValueOf(teacher, "Email")) ? "-" : teacherValueOf(teacher, "Email"))</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="bg-surface-container-lowest border border-outline-variant rounded-2xl overflow-hidden">
                <div class="p-6 border-b border-outline-variant flex items-center justify-between">
                    <h3 class="text-lg font-bold text-primary">حالة طلبات الاختبار</h3>
                    <div class="flex items-center gap-2">
                        <a class="px-4 py-2 rounded-full bg-primary text-white text-xs font-bold" href="@Url.Action("MyExams", "Student", new { userId = studentUserId })">فتح الاختبارات</a>
                        <a class="px-4 py-2 rounded-full bg-tertiary text-white text-xs font-bold" href="@Url.Action("MyRecitationSessions", "Student", new { userId = studentUserId })">جلسات التسميع</a>
                    </div>
                </div>
                <div class="p-6">
                    @if (studentExamRequests == null)
                    {
                        <div class="border border-dashed border-outline-variant rounded-xl p-4 text-sm text-on-surface-variant">لا توجد طلبات اختبارات ظاهرة حالياً.</div>
                    }
                    else
                    {
                        var anyRequest = false;
                        <div class="space-y-3">
                            @foreach (var req in studentExamRequests)
                            {
                                anyRequest = true;
                                var reqTitle = valueOf(req, "Title");
                                var reqStatus = valueOf(req, "Status");
                                var reqTeacherName = valueOf(req, "TeacherName");
                                var reqGrade = valueOf(req, "Grade");
                                var reqCreatedAt = dateOf(req, "CreatedAt");
                                <div class="rounded-xl border border-outline-variant bg-surface-container-low p-4">
                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                        <strong>@(string.IsNullOrWhiteSpace(reqTitle) ? "طلب اختبار" : reqTitle)</strong>
                                        <span class="text-xs font-bold text-primary">@((string.IsNullOrWhiteSpace(reqStatus) ? "-" : reqStatus))</span>
                                    </div>
                                    <div class="mt-2 text-sm text-on-surface-variant leading-7">
                                        <div><strong>المعلم:</strong> @(string.IsNullOrWhiteSpace(reqTeacherName) ? "لم يتم التعيين" : reqTeacherName)</div>
                                        <div><strong>التقدير:</strong> @(string.IsNullOrWhiteSpace(reqGrade) ? "-" : reqGrade)</div>
                                        <div><strong>تاريخ الطلب:</strong> @(reqCreatedAt.HasValue ? reqCreatedAt.Value.ToString("yyyy/MM/dd HH:mm") : "-")</div>
                                    </div>
                                </div>
                            }
                            @if (!anyRequest)
                            {
                                <div class="border border-dashed border-outline-variant rounded-xl p-4 text-sm text-on-surface-variant">لا توجد طلبات اختبار بعد.</div>
                            }
                        </div>
                    }
                </div>
            </section>
        </div>
    </main>
    <script>
        (function () {
            var current = 1;
            var max = 5;
            var panes = document.querySelectorAll(".step-pane");
            var indicators = document.querySelectorAll(".step-indicator");
            function showStep(step) {
                current = step;
                panes.forEach(function (p) {
                    p.classList.toggle("active", parseInt(p.getAttribute("data-step"), 10) === step);
                });
                indicators.forEach(function (i) {
                    i.classList.toggle("active", parseInt(i.getAttribute("data-step-ind"), 10) <= step);
                });
            }
            document.querySelectorAll(".next-step").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    if (current < max) showStep(current + 1);
                });
            });
            document.querySelectorAll(".prev-step").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    if (current > 1) showStep(current - 1);
                });
            });
            showStep(1);
        })();
    </script>
</body>
</html>

